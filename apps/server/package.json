{
  "name": "yidhras-server",
  "version": "0.1.0",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:workers": "bash -c 'for i in $(seq 0 $((${WORKERS:-2} - 1))); do SCHEDULER_WORKER_INDEX=$i SCHEDULER_WORKER_TOTAL=${WORKERS:-2} tsx src/index.ts & done; wait'",
    "serve:test-server": "tsx src/index.ts",
    "prepare:runtime": "pnpm exec prisma migrate deploy --schema=prisma/schema.${PRISMA_DB_PROVIDER:-sqlite}.prisma && pnpm run init:runtime && pnpm run seed:identity && pnpm run seed:operator",
    "reset:dev-db": "tsx src/init/reset_dev_db.ts",
    "postinstall": "pnpm exec prisma generate --schema=prisma/schema.${PRISMA_DB_PROVIDER:-sqlite}.prisma",
    "check:rust": "cargo check --manifest-path rust/world_engine_sidecar/Cargo.toml && cargo check --manifest-path rust/scheduler_decision_sidecar/Cargo.toml && cargo check --manifest-path rust/memory_trigger_sidecar/Cargo.toml",
    "build:rust": "cargo build --manifest-path rust/world_engine_sidecar/Cargo.toml && cargo build --manifest-path rust/scheduler_decision_sidecar/Cargo.toml && cargo build --manifest-path rust/memory_trigger_sidecar/Cargo.toml",
    "build": "tsc",
    "test": "pnpm run test:unit && pnpm run test:integration && pnpm run test:e2e",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:unit:watch": "vitest --config vitest.unit.config.ts --watch",
    "test:integration:watch": "vitest --config vitest.integration.config.ts --watch",
    "test:e2e:watch": "vitest --config vitest.e2e.config.ts --watch",
    "start": "node dist/index.js",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "init:configw": "tsx src/init/init_configw.ts",
    "init:world-pack": "tsx src/init/init_world_pack.ts",
    "init:runtime": "tsx src/init/prepare_runtime.ts",
    "scaffold:world-pack": "tsx src/init/scaffold_world_pack.ts",
    "db": "tsx src/cli/db_cli.ts",
    "sim": "tsx src/cli/sim_cli.ts",
    "ai": "tsx src/cli/ai_cli.ts",
    "diag": "tsx src/cli/diag_cli.ts",
    "operator": "tsx src/cli/operator_cli.ts",
    "plugin": "tsx src/cli/plugin_cli.ts",
    "snapshot": "tsx src/cli/snapshot_cli.ts",
    "validate:pack": "tsx src/cli/validate_pack_cli.ts",
    "pack:export": "tsx src/cli/pack_export_cli.ts export",
    "pack:import": "tsx src/cli/pack_export_cli.ts import",
    "config:backup": "tsx src/cli/config_backup_cli.ts",
    "config:backup:create": "tsx src/cli/config_backup_cli.ts create",
    "config:backup:list": "tsx src/cli/config_backup_cli.ts list",
    "config:backup:cleanup": "tsx src/cli/config_backup_cli.ts cleanup",
    "seed:identity": "tsx src/db/seed_identity.ts",
    "seed:operator": "tsx src/db/seed_operator.ts",
    "smoke": "vitest run --config vitest.e2e.config.ts tests/e2e/smoke-startup.spec.ts tests/e2e/smoke-endpoints.spec.ts",
    "manual:world-pack-runtime-demo": "tsx scripts/manual/world_pack_runtime_demo.ts",
    "manual:clock-demo": "tsx scripts/manual/clock_demo.ts",
    "manual:clock-raw": "tsx scripts/manual/clock_raw.ts",
    "manual:dynamics-demo": "tsx scripts/manual/dynamics_demo.ts",
    "manual:dynamics-pluggable-demo": "tsx scripts/manual/dynamics_pluggable_demo.ts",
    "manual:narrative-demo": "tsx scripts/manual/narrative_demo.ts",
    "manual:permission-demo": "tsx scripts/manual/permission_demo.ts",
    "manual:world-pack-demo": "tsx scripts/manual/world_pack_demo.ts"
  },
  "dependencies": {
    "@yidhras/contracts": "workspace:*",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "sqlite3": "^5.1.7",
    "tiktoken": "^1.0.22",
    "yaml": "^2.3.4",
    "zod": "^4.1.5",
    "zod-validation-error": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@prisma/client": "^6.2.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.28",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "fast-check": "^4.7.0",
    "prettier": "^3.6.2",
    "prisma": "^6.2.1",
    "tsx": "^4.7.1",
    "typescript": "^5.4.2",
    "typescript-eslint": "^8.46.1",
    "vitest": "^3.2.4"
  }
}
