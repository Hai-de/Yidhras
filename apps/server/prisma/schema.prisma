// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// --- L1 & L2: Agent & Identity ---

model Agent {
  id              String   @id @default(uuid())
  name            String
  type            String   // "active", "noise", "system"
  
  // Value Dynamics
  snr             Float    @default(0.5) // 信噪比 (0.0 - 1.0)
  is_pinned       Boolean  @default(false)
  
  // Relations
  posts           Post[]
  relationships_from Relationship[] @relation("FromNode")
  relationships_to   Relationship[] @relation("ToNode")

  identity_bindings IdentityNodeBinding[]
  
  // Atmosphere Nodes (Sockpuppets)
  atmosphere_nodes AtmosphereNode[]
  
  // Circles (Permissions)
  circle_memberships CircleMember[]

  created_at      BigInt
  updated_at      BigInt
}

model AtmosphereNode {
  id              String   @id @default(uuid())
  name            String
  owner_id        String
  owner           Agent    @relation(fields: [owner_id], references: [id])

  identity_bindings IdentityNodeBinding[]
  
  expires_at      BigInt?  // 自动回收时间
  created_at      BigInt
}

// --- Permission System ---

model Circle {
  id          String         @id @default(uuid())
  name        String
  level       Int            // AccessLevel Enum (0-3)
  description String?
  
  members     CircleMember[]
}

model CircleMember {
  agent_id    String
  circle_id   String
  agent       Agent    @relation(fields: [agent_id], references: [id])
  circle      Circle   @relation(fields: [circle_id], references: [id])

  @@id([agent_id, circle_id])
}

// --- L2: Relationship Graph ---

model Relationship {
  id          String   @id @default(uuid())
  from_id     String
  to_id       String
  type        String   // "friend", "enemy", "command", "transfer"
  weight      Float    @default(1.0)
  
  from        Agent    @relation("FromNode", fields: [from_id], references: [id])
  to          Agent    @relation("ToNode", fields: [to_id], references: [id])

  created_at  BigInt
}

// --- L1: Social Layer ---

model Post {
  id          String   @id @default(uuid())
  author_id   String
  content     String
  
  // L4 Transmission Props
  noise_level Float    @default(0.0)
  is_encrypted Boolean @default(false)
  
  author      Agent    @relation(fields: [author_id], references: [id])
  
  created_at  BigInt
}

// --- L3: Narrative Layer ---

model Event {
  id          String   @id @default(uuid())
  title       String
  description String
  tick        BigInt   // 发生时的绝对时间
  type        String   // "history", "interaction", "system"
  
  // 影响范围 (JSON)
  impact_data String?  // 存储 JSON: { "snr_delta": ..., "affected_nodes": [] }
}

model WorldVariable {
  key         String   @id
  value       String
  updated_at  BigInt
}

// --- Identity Layer ---

model Identity {
  id         String  @id @default(uuid())
  type       String
  name       String?
  provider   String  @default("m2")
  status     String  @default("active")
  claims     Json?
  metadata   Json?
  created_at BigInt
  updated_at BigInt

  policies   Policy[]
  bindings   IdentityNodeBinding[]
}

model IdentityNodeBinding {
  id                  String   @id @default(uuid())
  identity_id         String
  agent_id            String?
  atmosphere_node_id  String?
  role                String
  status              String   @default("active")
  expires_at          BigInt?
  created_at          BigInt
  updated_at          BigInt

  identity        Identity       @relation(fields: [identity_id], references: [id])
  agent           Agent?         @relation(fields: [agent_id], references: [id])
  atmosphere_node AtmosphereNode? @relation(fields: [atmosphere_node_id], references: [id])

  @@index([identity_id])
  @@index([agent_id])
  @@index([atmosphere_node_id])
  @@index([role, status])
}

model Policy {
  id            String   @id @default(uuid())
  effect        String
  subject_id    String?
  subject_type  String?
  resource      String
  action        String
  field         String
  conditions    Json?
  priority      Int      @default(0)
  created_at    BigInt
  updated_at    BigInt

  subject       Identity? @relation(fields: [subject_id], references: [id])

  @@index([resource, action])
  @@index([subject_id])
  @@index([subject_type])
}

model InferenceTrace {
  id               String      @id
  kind             String
  strategy         String
  provider         String
  actor_ref        Json
  input            Json
  context_snapshot Json
  prompt_bundle    Json
  trace_metadata   Json
  decision         Json?
  created_at       BigInt
  updated_at       BigInt

  action_intent    ActionIntent?
  decision_job     DecisionJob?

  @@index([kind, created_at])
  @@index([strategy, provider])
}

model ActionIntent {
  id                    String         @id @default(uuid())
  source_inference_id   String         @unique
  intent_type           String
  actor_ref             Json
  target_ref            Json?
  payload               Json
  scheduled_after_ticks BigInt?
  scheduled_for_tick    BigInt?
  status                String         @default("pending")
  dispatch_started_at   BigInt?
  dispatched_at         BigInt?
  transmission_delay_ticks BigInt?
  transmission_policy   String         @default("reliable")
  transmission_drop_chance Float        @default(0)
  drop_reason           String?
  dispatch_error_code   String?
  dispatch_error_message String?
  created_at            BigInt
  updated_at            BigInt

  source_inference      InferenceTrace @relation(fields: [source_inference_id], references: [id])
  decision_job          DecisionJob?

  @@index([status, created_at])
}

model DecisionJob {
  id                  String          @id @default(uuid())
  source_inference_id String?         @unique
  action_intent_id    String?         @unique
  job_type            String
  status              String
  idempotency_key     String?         @unique
  attempt_count       Int             @default(1)
  max_attempts        Int             @default(3)
  request_input       Json?
  last_error          String?
  last_error_code     String?
  last_error_stage    String?
  started_at          BigInt?
  next_retry_at       BigInt?
  created_at          BigInt
  updated_at          BigInt
  completed_at        BigInt?

  source_inference    InferenceTrace? @relation(fields: [source_inference_id], references: [id])
  action_intent       ActionIntent?   @relation(fields: [action_intent_id], references: [id])

  @@index([status, created_at])
}
