{
  "name": "yidhras-workspace",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm -r --parallel --filter yidhras-server --filter web dev",
    "dev:server": "pnpm --filter yidhras-server dev",
    "dev:web": "pnpm --filter web dev",
    "build": "pnpm --filter yidhras-server build && pnpm --filter web build",
    "lint": "pnpm --filter yidhras-server lint && pnpm --filter web lint",
    "test": "pnpm --filter web test:unit && pnpm --filter yidhras-server test",
    "test:unit": "pnpm --filter web test:unit && pnpm --filter yidhras-server test:unit",
    "test:integration": "pnpm --filter yidhras-server test:integration",
    "test:e2e": "pnpm --filter yidhras-server test:e2e",
    "test:unit:watch": "pnpm -r --parallel --filter web --filter yidhras-server test:unit:watch",
    "test:integration:watch": "pnpm --filter yidhras-server test:integration:watch",
    "test:e2e:watch": "pnpm --filter yidhras-server test:e2e:watch",
    "typecheck": "pnpm --filter yidhras-server typecheck && pnpm --filter web typecheck",
    "prepare:runtime": "pnpm --filter yidhras-server prepare:runtime",
    "scaffold:world-pack": "pnpm --filter yidhras-server scaffold:world-pack",
    "prepare": "simple-git-hooks",
    "smoke:server": "pnpm --filter yidhras-server smoke",
    "depcruise": "bash -c 'cd apps/server && pnpm exec dependency-cruiser --config ../../.dependency-cruiser.js src --ts-config tsconfig.json'",
    "depcruise:web": "bash -c 'cd apps/web && pnpm exec dependency-cruiser --config ../../.dependency-cruiser.js . --ts-config tsconfig.json'"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "lint-staged": {
    "apps/server/src/**/*.ts": [
      "pnpm --filter yidhras-server exec eslint --fix"
    ],
    "apps/server/tests/**/*.ts": [
      "pnpm --filter yidhras-server exec eslint --fix"
    ],
    "apps/server/scripts/**/*.ts": [
      "pnpm --filter yidhras-server exec eslint --fix"
    ],
    "apps/server/builtin/**/*.ts": [
      "pnpm --filter yidhras-server exec eslint --fix"
    ],
    "apps/web/**/*.{ts,vue}": [
      "pnpm --filter web exec eslint --fix"
    ]
  },
  "devDependencies": {
    "dependency-cruiser": "^17.4.3",
    "lint-staged": "^17.0.5",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3"
  }
}
